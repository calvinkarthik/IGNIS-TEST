# Copy this file to ignis-poc.env on the Pi. Never commit the copied file.
export IGNIS_BACKEND_HOST='192.168.137.1'
export IGNIS_BACKEND_PORT='9001'
export IGNIS_DEVICE_TOKEN='replace-this-poc-token'
export IGNIS_DEVICE_ID='ignis-qnxpi-01'

# Use 0 only if the verified QNX camera path is exposed to OpenCV. Otherwise put
# the exact capture pipeline/string from the camera sample that works on this Pi.
export IGNIS_CAMERA_SOURCE='0'

export IGNIS_MODEL_PATH='qnx/models/fire_smoke_detector.tflite'
export IGNIS_MODEL_MANIFEST='qnx/models/model_manifest.json'
export IGNIS_POC_LOG='poc/pi/data/ignis-poc.jsonl'
